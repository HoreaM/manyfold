<ul class="list-unstyled">
  <% if collection.remote? %>
    <% if (creator = collection.federails_actor.extensions["attributedTo"]) %>
      <li>
        <%= Icon icon: "person", label: Creator.model_name.human %>
        <%= link_to creator["name"], creator["url"] %><br>
      </li>
    <% end %>
    <%- collections = Array.new(collection.federails_actor.extensions["context"] || []) %>
    <% if (collections.any?) %>
      <li>
        <%= Icon icon: "collection", label: Collection.model_name.human %>
        <%= link_to collections.first["name"], collections.first["url"] %>
        <%= content_tag(:span) { "+#{collections.count - 1}" } if collections.count > 1 %>
      </li>
    <% end %>
  <% else %>
    <% if collection.creator %>
      <li>
        <%= Icon icon: "person", label: Creator.model_name.human %>
        <%= link_to collection.creator.name, collections_path({creator: collection.creator}.merge(@filter.to_params)) %><br>
      </li>
    <% end %>
    <% if collection.collection %>
      <li>
        <%= Icon icon: "collection", label: Collection.model_name.human %>
        <%= link_to collection.collection.name, collection, @filter.to_params %><br>
      </li>
    <% end %>
  <% end %>
</ul>
